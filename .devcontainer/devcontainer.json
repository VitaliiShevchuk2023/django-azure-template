{
  "name": "Django Azure Security Template",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",

  "features": {
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest",
      "tflint": "latest"
    },
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "hashicorp.terraform",
        "hashicorp.hcl",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-vscode.azurecli",
        "GitHub.vscode-pull-request-github",
        "ms-azuretools.vscode-azureterraform"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.linting.flake8Enabled": true,
        "editor.formatOnSave": true,
        "editor.rulers": [120],
        "[terraform]": {
          "editor.defaultFormatter": "hashicorp.terraform",
          "editor.formatOnSave": true,
          "editor.tabSize": 2
        },
        "[terraform-vars]": {
          "editor.defaultFormatter": "hashicorp.terraform",
          "editor.formatOnSave": true
        },
        "terraform.languageServer": {
          "enabled": true,
          "args": ["serve"]
        }
      }
    },
    "codespaces": {
      "openFiles": [
        "README.md"
      ]
    }
  },

  "postCreateCommand": "pip install -r requirements.txt && pip install pytest pytest-django coverage flake8 && echo '✅ Python deps installed' && terraform version && az version",

  "remoteEnv": {
    "TF_LOG": "WARN",
    "TF_CLI_ARGS_plan": "-compact-warnings",
    "DJANGO_SETTINGS_MODULE": "djangoapp.settings"
  },

  "forwardPorts": [8000],

  "portsAttributes": {
    "8000": {
      "label": "Django Dev Server",
      "onAutoForward": "notify"
    }
  }
}
