# Microsoft Entra ID
AZURE_CLIENT_ID=your-entra-app-client-id
AZURE_CLIENT_SECRET=your-entra-app-client-secret
AZURE_TENANT_ID=your-tenant-id
AZURE_REDIRECT_URI=https://your-app.azurewebsites.net/auth/callback/

# Django
SECRET_KEY=your-django-secret-key-min-50-chars
DEBUG=False
ALLOWED_HOSTS=your-app.azurewebsites.net,localhost

# PostgreSQL
DB_HOST=your-db.postgres.database.azure.com
DB_NAME=djangodb
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Azure Resources
AZURE_KEY_VAULT_NAME=your-kv-name
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
